# Copy to rust/.env and adjust. Loaded by dev tooling; never commit the real .env.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev/test default matches scripts/test-db.sh (Apple `container` Postgres).
DATABASE_URL=postgres://postgres:dev@localhost:5432/decodingus?sslmode=disable

# ── Web ───────────────────────────────────────────────────────────────────────
PORT=9000
RUST_LOG=info,du_web=debug
# Signing key for session cookies (generate a long random value in prod).
APP_SECRET=changeme

# ── External integrations (filled in as subsystems are ported) ─────────────────
# OPENALEX_BASE_URL=https://api.openalex.org
# ENA_BASE_URL=https://www.ebi.ac.uk/ena/portal/api
# AWS_REGION=us-east-1
# RECAPTCHA_ENABLED=false
